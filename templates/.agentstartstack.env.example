# Agent session workflow identity
# Copy to host project root as .agentstartstack.env (add-to-project.sh does this automatically)

PROJECT_NAME=myproject
DISPLAY_NAME=myproject
# Canonical local repo path. Defaults to this repo's root (the directory holding
# this .agentstartstack.env). Set it only if your checkout lives elsewhere.
# CANONICAL_LOCAL_REPO="/path/to/myproject"
ORIGIN_URL=git@github.com:farscapian/myproject.git

# Optional: pgrep -af pattern while long-running CLI is active (ass up trim /
# ass publish skip trimming that consumer's clones while it matches)
# ACTIVE_GUARD_PGREP=myproject (build|flash)

# Optional: where ass up trim archives stale session clones
# AGENTSTARTSTACK_CLONE_ARCHIVE_DIR="${HOME}/.myproject/archives/agent_clones"

# Optional: ass publish auto-trims session clones after each consumer (default on)
# ASS_PUBLISH_AUTOTRIM=0

# Optional: append a full transcript of every ass command to
# ~/.agentstartstack/ass.log (override path with AGENTSTARTSTACK_LOG_FILE).
# LOG_TO_FILE=1
