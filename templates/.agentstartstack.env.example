# Agent session workflow identity
# Copy to host project root as .agentstartstack.env (add-to-project.sh does this automatically)

PROJECT_NAME=myproject
DISPLAY_NAME=myproject
SYNC_REPO="${HOME}/Sync/mini_projects/myproject"
ORIGIN_URL=git@github.com:farscapian/myproject.git

# Optional: pgrep -af pattern while long-running CLI is active (nut refuses)
# ACTIVE_GUARD_PGREP=myproject (build|flash)